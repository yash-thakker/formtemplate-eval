{
  "name": "form-extraction-eval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local benchmark/eval framework for AEC form PDF extraction pipelines",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "eval": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "eval": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@aws-sdk/client-textract": "^3.700.0",
    "ai": "^4.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-levenshtein": "^3.0.0",
    "munkres-js": "^1.2.2",
    "pdf-to-png-converter": "^3.3.0",
    "pdfjs-dist": "^4.7.76",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
